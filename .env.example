# ShipSmart Orchestrator (Java API) - environment variables
# Copy to .env and fill in real values for local development.
# Production values are set in the Render dashboard (never commit real secrets).

SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local
REQUIRE_JWT_SECRET=false

# Database (Supabase PostgreSQL)
DATABASE_URL=jdbc:postgresql://db.your-project-ref.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=your-supabase-db-user
DATABASE_PASSWORD=your-supabase-db-password

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# CORS & inter-service
CORS_ALLOWED_ORIGINS=http://localhost:5173
INTERNAL_PYTHON_API_URL=http://localhost:8000

# FedEx Real API Integration
FEDEX_BASE_URL=https://apis.fedex.com
FEDEX_CLIENT_ID=your-fedex-client-id
FEDEX_CLIENT_SECRET=your-fedex-client-secret
FEDEX_ACCOUNT_NUMBER=your-fedex-account-number
